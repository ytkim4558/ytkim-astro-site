#!/bin/sh

FILE_AGENTS="AGENTS.md"
FILE_STEERING=".kiro/steering.md"

# 스테이징된 파일이 무엇인지 감지
STAGED_AGENTS=$(git diff --cached --name-only | grep -x "$FILE_AGENTS")
STAGED_STEERING=$(git diff --cached --name-only | grep -x "$FILE_STEERING")

# AGENTS.md만 커밋하려는 경우 -> steering.md에 덮어쓰고 같이 커밋
if [ -n "$STAGED_AGENTS" ] && [ -z "$STAGED_STEERING" ]; then
    mkdir -p .kiro
    cp "$FILE_AGENTS" "$FILE_STEERING"
    git add "$FILE_STEERING"
# steering.md만 커밋하려는 경우 -> AGENTS.md에 덮어쓰고 같이 커밋
elif [ -z "$STAGED_AGENTS" ] && [ -n "$STAGED_STEERING" ]; then
    cp "$FILE_STEERING" "$FILE_AGENTS"
    git add "$FILE_AGENTS"
fi

exit 0
