#!/bin/sh

FILE_AGENTS="AGENTS.md"
FILE_STEERING=".kiro/steering.md"

if [ -f "$FILE_AGENTS" ] && [ -f "$FILE_STEERING" ]; then
    # Windows CRLF vs LF 차이를 무시하고 실제 텍스트 내용만 비교
    if ! diff -q --strip-trailing-cr "$FILE_AGENTS" "$FILE_STEERING" > /dev/null 2>&1; then
        echo "============================================================"
        echo "ERROR: AGENTS.md and .kiro/steering.md are out of sync!"
        echo "Please synchronize them manually before committing."
        echo "You can copy one to the other, e.g.:"
        echo "  cp $FILE_AGENTS $FILE_STEERING"
        echo "============================================================"
        exit 1
    fi
fi

exit 0
