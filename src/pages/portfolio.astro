      <p class="eyebrow" id="portfolio-modal-meta"></p>
      <h2 id="portfolio-modal-title"></h2>
      <p id="portfolio-modal-body"></p>
      <div id="portfolio-modal-content" class="portfolio-modal-content"></div>
    </form>
  </dialog>

  <script>
    const modal = document.querySelector('#portfolio-modal');
    const modalTitle = document.querySelector('#portfolio-modal-title');
    const modalMeta = document.querySelector('#portfolio-modal-meta');
    const modalBody = document.querySelector('#portfolio-modal-body');
    const modalContent = document.querySelector('#portfolio-modal-content');

    function cloneDetailContent(selector) {
      const target = document.querySelector(selector);
      if (!target || !modalContent) return;

      modalContent.replaceChildren();

      if (target.matches('section')) {
        modalContent.append(...Array.from(target.children).map((child) => child.cloneNode(true)));
        return;
      }

      const root = target.closest('.company-heading, h2, h3, li') || target;
      const boundary = root.matches('.company-heading')
        ? '.company-heading, h1'
        : root.matches('h2')
          ? 'h1, h2, .company-heading'
          : root.matches('h3')
            ? 'h2, h3, .company-heading'
            : 'h1, h2, h3, .company-heading';
      modalContent.append(root.cloneNode(true));

      let next = root.nextElementSibling;
      while (next && !next.matches(boundary)) {
        modalContent.append(next.cloneNode(true));
        next = next.nextElementSibling;
      }
    }

    document.querySelectorAll('[data-portfolio-modal]').forEach((card) => {
      card.addEventListener('click', (event) => {
        if (!modal || typeof modal.showModal !== 'function') return;
        event.preventDefault();
        modalTitle.textContent = card.dataset.modalTitle || '';
        modalMeta.textContent = card.dataset.modalMeta || '';
        modalBody.textContent = card.dataset.modalBody || '';
        cloneDetailContent(card.getAttribute('href') || '#selected-work');
        modal.showModal();
      });
    });

    modal?.addEventListener('click', (event) => {
      if (event.target === modal) modal.close();
    });
  </script>

