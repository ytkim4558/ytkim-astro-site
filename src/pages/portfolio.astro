---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const details = await getEntry('portfolio', 'details');
if (!details) {
  throw new Error('Missing portfolio details content');
}
const { Content } = await render(details);
