---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const toSlug = (value: string) => value.toLowerCase().replace(/\s+/g, '-');
const descriptions: Record<string, string> = {
  'ai-workflow': 'AIコーディングエージェントと作ったツール、ワークフロー、設計判断の記録。',
  troubleshooting: '問題調査と復旧の記録。',
  jekyll: '旧Jekyll静的サイトの保守記録。',
  mysql: 'MySQLに関するメモ。',
  git: 'Git運用とデプロイの整理。',
  android: 'Androidアプリ開発の記録。',
};

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagMap = new Map<string, { label: string; count: number }>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    const slug = toSlug(tag);
    const current = tagMap.get(slug);
    tagMap.set(slug, { label: current?.label ?? tag, count: (current?.count ?? 0) + 1 });
  }
}

const tags = [...tagMap.entries()].sort((a, b) => b[1].count - a[1].count || a[1].label.localeCompare(b[1].label));
---

<BaseLayout title="Tags | Yongtak Kim">
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Tags</p>
      <h1>トピック別ノート</h1>
      <p class="hero-description">OpenSearch、AI Workflow、Git、Android、トラブルシューティングなどの技術ノートをトピック別に整理しています。</p>
    </div>
  </section>
  <section class="card-grid">
    {tags.map(([slug, tag]) => (
      <a class="feature-card" href={`/ja/tag/${slug}/`}>
        <span>{tag.count} posts</span>
        <strong>#{slug}</strong>
        <p>{descriptions[slug] ?? `${tag.label} 関連ノート`}</p>
      </a>
    ))}
  </section>
</BaseLayout>
