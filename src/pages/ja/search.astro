---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { jaPosts } from '../../i18n-posts';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .map((post) => {
    const slug = post.id.replace(/\.(md|mdx)$/, '').toLowerCase();
    const localized = jaPosts[slug];
    return {
      title: localized?.title ?? post.data.title,
      description: localized?.description ?? post.data.description ?? '',
      tags: post.data.tags,
      url: `/ja/${slug}/`,
    };
  });
---

<BaseLayout title="Search | Yongtak Kim">
  <section class="page-hero localized-hero">
    <div class="hero-inner">
      <p class="eyebrow">Search</p>
      <h1>ノート検索</h1>
      <p class="hero-description">タイトル、説明、タグを対象にローカル検索します。</p>
    </div>
  </section>
  <main class="content">
    <label class="search-label" for="search-input">Search query</label>
    <input id="search-input" class="search-input" type="search" placeholder="OpenSearch, Codex, Git..." />
    <div id="search-results" class="post-list compact"></div>
  </main>
  <script define:vars={{ posts }}>
    const input = document.querySelector('#search-input');
    const results = document.querySelector('#search-results');
    const render = (items) => {
      results.innerHTML = items.map((post) => `
        <article class="post-list-item">
          <a href="${post.url}">
            <span>${post.tags.join(' · ')}</span>
            <strong>${post.title}</strong>
            <p>${post.description}</p>
          </a>
        </article>
      `).join('');
    };
    input.addEventListener('input', () => {
      const query = input.value.trim().toLowerCase();
      const filtered = query
        ? posts.filter((post) => [post.title, post.description, post.tags.join(' ')].join(' ').toLowerCase().includes(query))
        : posts;
      render(filtered);
    });
    render(posts);
  </script>
</BaseLayout>
