---
import BaseLayout from '../layouts/BaseLayout.astro';

import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const formatDate = (date: Date) => new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<BaseLayout title="Yongtak Kim Engineering Notes">
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Cloud Analytics · AI Workflow · Portfolio</p>
      <h1>반복되는 엔지니어링 문제를 기록하고 도구로 바꾸는 노트</h1>
      <p class="hero-description">
        OpenSearch, AWS Support, 데이터 플랫폼, AI workflow 실험을 정리하는 개인 기술 사이트입니다.
      </p>
    </div>
  </section>

  <section class="card-grid" aria-label="Primary sections">
    <a class="feature-card" href="/profile/">
      <span>Profile</span>
      <strong>지원 엔지니어링과 OpenSearch SME 경험</strong>
      <p>경력 요약, 핵심 기술, 프로필 Q&A를 정리합니다.</p>
    </a>
    <a class="feature-card" href="/portfolio/">
      <span>Portfolio</span>
      <strong>10년 이상의 개발·데이터 플랫폼 이력</strong>
      <p>프로젝트, 고객 지원 사례, 자동화 흐름을 한 페이지에 모읍니다.</p>
    </a>
    <a class="feature-card" href="/tag/ai-workflow/">
      <span>AI Workflow</span>
      <strong>AI 에이전트와 운영 자동화 기록</strong>
      <p>Codex, Claude, MCP, handoff 규칙을 재사용 가능한 글로 남깁니다.</p>
    </a>
    <a class="feature-card" href={`/${posts[0].id.replace(/\.(md|mdx)$/, '')}/`}>
      <span>Latest Note</span>
      <strong>{posts[0].data.title}</strong>
      <p>{posts[0].data.description}</p>
    </a>
  </section>

  <main class="post-list">
    {posts.map((post) => (
      <article class="post-list-item">
        <a href={`/${post.id.replace(/\.(md|mdx)$/, '')}/`}>
          <span>{formatDate(post.data.pubDate)} · {post.data.tags.join(' · ')}</span>
          <strong>{post.data.title}</strong>
          {post.data.description && <p>{post.data.description}</p>}
        </a>
      </article>
    ))}
  </main>
</BaseLayout>
