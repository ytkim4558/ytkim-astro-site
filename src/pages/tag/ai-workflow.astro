---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft && data.tags.includes('AI Workflow'));
---

<BaseLayout title="AI Workflow | Yongtak Kim">
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">AI Workflow</p>
      <h1>에이전트 작업을 재현 가능한 워크플로로 남기는 기록</h1>
    </div>
  </section>
  <main class="content">
    <h2>Notes</h2>
    {posts.map((post) => (
      <p>
        <a href={`/posts/${post.id.replace(/\.(md|mdx)$/, '')}/`}>
          <strong>{post.data.title}</strong>
        </a>
        <br />
        {post.data.description}
      </p>
    ))}
  </main>
</BaseLayout>
