---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const toSlug = (value: string) => value.toLowerCase().replace(/\s+/g, '-');
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags.map(toSlug)))].sort();
  return tags.map((tag) => ({ params: { tag }, props: { tag, posts } }));
}

const toSlug = (value: string) => value.toLowerCase().replace(/\s+/g, '-');
const { tag, posts } = Astro.props;
const filteredPosts = posts
  .filter((post) => post.data.tags.some((item) => toSlug(item) === tag))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const label = filteredPosts[0]?.data.tags.find((item) => toSlug(item) === tag) ?? tag;
const formatDate = (date: Date) => new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<BaseLayout title={`${label} | Yongtak Kim`}>
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Yongtak Kim</p>
      <h1>{label}</h1>
      <p class="hero-description">
        {filteredPosts.length}개의 관련 노트를 최신순으로 정리합니다.
      </p>
    </div>
  </section>
  <main class="post-list">
    {filteredPosts.map((post) => (
      <article class="post-list-item">
        <a href={`/${post.id.replace(/\.(md|mdx)$/, '')}/`}>
          <span>{formatDate(post.data.pubDate)}</span>
          <strong>{post.data.title}</strong>
          {post.data.description && <p>{post.data.description}</p>}
        </a>
      </article>
    ))}
  </main>
</BaseLayout>
