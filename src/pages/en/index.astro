---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Yongtak Kim Engineering Notes">
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Cloud Analytics · AI Workflow · Portfolio</p>
      <h1>Engineering notes on support automation, OpenSearch, and AI workflows</h1>
      <p class="hero-description">
        English entry point for profile, portfolio, and AI workflow notes.
      </p>
    </div>
  </section>

  <section class="card-grid" aria-label="English sections">
    <a class="feature-card" href="/en/about/">
      <span>Profile</span>
      <strong>AWS support engineering and OpenSearch SME work</strong>
      <p>Short English summary of current focus and selected tools.</p>
    </a>
    <a class="feature-card" href="/en/portfolio/">
      <span>Portfolio</span>
      <strong>Support automation and data platform background</strong>
      <p>Experience across AWS Analytics, data platforms, mobile apps, and AI workflow tooling.</p>
    </a>
    <a class="feature-card" href="/tag/ai-workflow/">
      <span>Workflow</span>
      <strong>AI-agent workflow records</strong>
      <p>Korean notes for implementation decisions, handoff rules, and tool-building history.</p>
    </a>
