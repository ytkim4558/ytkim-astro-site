---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Yongtak Kim Engineering Notes">
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Cloud Analytics · AI Workflow · Portfolio</p>
      <h1>Engineering notes from cloud support, data platforms, and AI-assisted workflows</h1>
      <p class="hero-description">
        A portfolio and engineering notebook focused on OpenSearch troubleshooting, analytics support, data-platform work, and practical AI-agent automation.
      </p>
    </div>
  </section>

  <section class="card-grid" aria-label="English sections">
    <a class="feature-card" href="/en/about/">
      <span>Profile</span>
      <strong>AWS support engineering and OpenSearch SME work</strong>
      <p>Current focus, technical background, and selected tools in a concise profile.</p>
    </a>
    <a class="feature-card" href="/en/portfolio/">
      <span>Portfolio</span>
      <strong>Support automation and data platform background</strong>
      <p>Experience across AWS Analytics, data platforms, mobile apps, and AI workflow tooling.</p>
    </a>
    <a class="feature-card" href="/en/tag/ai-workflow/">
      <span>Workflow</span>
      <strong>AI-agent workflow records</strong>
      <p>Implementation decisions, handoff rules, and tool-building history for AI-assisted engineering.</p>
    </a>
  </section>
</BaseLayout>
