---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Portfolio | Yongtak Kim">
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">OpenSearch · Support Automation · AI Workflow</p>
      <h1>A support engineer who turns repeated troubleshooting patterns into reliable tools</h1>
      <p class="hero-description">
        AWS Cloud Support Engineer and OpenSearch SME with experience across analytics workloads, enterprise data platforms, mobile apps, backend systems, and AI-assisted workflows.
      </p>
    </div>
  </section>

  <nav class="section-links" aria-label="Portfolio sections">
    <a href="#profile">Profile</a>
    <a href="#experience">Experience</a>
    <a href="#automation">Automation</a>
    <a href="#tools">AI Tools</a>
    <a href="#background">Background</a>
  </nav>

  <section id="profile" class="section-panel">
    <p class="eyebrow">Profile</p>
    <h2>Yongtak Kim</h2>
    <ul>
      <li>Role: AWS Cloud Support Engineer / OpenSearch SME</li>
      <li>GitHub: <a href="https://github.com/ytkim4558/">ytkim4558</a></li>
      <li>LinkedIn: <a href="https://www.linkedin.com/in/yongtak-kim-b7553727/">Yongtak Kim</a></li>
      <li>Korean full portfolio: <a href="/portfolio/">Portfolio</a></li>
    </ul>
  </section>

