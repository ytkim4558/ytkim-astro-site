---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { enPosts } from '../../../i18n-posts';

export async function getStaticPaths() {
  const toSlug = (value: string) => value.toLowerCase().replace(/\s+/g, '-');
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags.map(toSlug)))].sort();
  return tags.map((tag) => ({ params: { tag }, props: { tag, posts } }));
}

const toSlug = (value: string) => value.toLowerCase().replace(/\s+/g, '-');
const formatTitle = (value: string) => value.split('-').map((part) => part.charAt(0).toUpperCase() + part.slice(1)).join(' ');
const { tag, posts } = Astro.props;
const filteredPosts = posts
  .filter((post) => post.data.tags.some((item) => toSlug(item) === tag))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const label = filteredPosts[0]?.data.tags.find((item) => toSlug(item) === tag) ?? formatTitle(tag);
const tagCopy: Record<string, { eyebrow: string; title: string; description: string }> = {
  'ai-workflow': {
    eyebrow: 'AI Workflow Notes',
    title: 'Reusable workflows built with AI coding agents',
    description: 'Notes on Codex, Claude, MCP, deployment recovery, session handoff, and practical rules for collaborating with AI agents.',
  },
};
const copy = tagCopy[tag] ?? {
  eyebrow: 'Topic Notes',
  title: label,
  description: 'A focused collection of engineering notes grouped by topic.',
};
const formatDate = (date: Date) => new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<BaseLayout title={`${label} | Yongtak Kim`}>
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">{copy.eyebrow}</p>
      <h1>{copy.title}</h1>
      <p class="hero-description">
        {copy.description}
      </p>
    </div>
  </section>
  <main class="post-list">
    {filteredPosts.map((post) => (
      <article class="post-list-item">
        <a href={`/en/${post.id.replace(/\.(md|mdx)$/, '').toLowerCase()}/`}>
          <span>{formatDate(post.data.pubDate)}</span>
          <strong>{enPosts[post.id.toLowerCase()]?.title ?? post.data.title}</strong>
          {(enPosts[post.id.toLowerCase()]?.description || post.data.description) && <p>{enPosts[post.id.toLowerCase()]?.description ?? post.data.description}</p>}
        </a>
      </article>
    ))}
  </main>
</BaseLayout>
