---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const toSlug = (value: string) => value.toLowerCase().replace(/\s+/g, '-');
const descriptions: Record<string, string> = {
  'ai-workflow': 'Tools, workflows, and design decisions made with AI coding agents.',
  troubleshooting: 'Troubleshooting and recovery notes.',
  jekyll: 'Maintenance notes from the former Jekyll static site.',
  mysql: 'MySQL usage notes.',
  git: 'Git operations and deployment notes.',
  android: 'Android app development notes.',
};

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tagMap = new Map<string, { label: string; count: number }>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    const slug = toSlug(tag);
    const current = tagMap.get(slug);
    tagMap.set(slug, { label: current?.label ?? tag, count: (current?.count ?? 0) + 1 });
  }
}

const tags = [...tagMap.entries()].sort((a, b) => b[1].count - a[1].count || a[1].label.localeCompare(b[1].label));
---

<BaseLayout title="Tags | Yongtak Kim">
  <section class="page-hero">
    <div class="hero-inner">
      <p class="eyebrow">Tags</p>
      <h1>Browse Notes by Topic</h1>
      <p class="hero-description">A topic index for OpenSearch, AI workflows, Git, Android, troubleshooting, and site maintenance notes.</p>
    </div>
  </section>
  <section class="card-grid">
    {tags.map(([slug, tag]) => (
      <a class="feature-card" href={`/en/tag/${slug}/`}>
        <span>{tag.count} posts</span>
        <strong>#{slug}</strong>
        <p>{descriptions[slug] ?? `${tag.label} notes`}</p>
      </a>
    ))}
  </section>
</BaseLayout>
