---
import '../styles/global.css';
import { getLocale, localeLabels, locales, localizePath, navLabels } from '../i18n';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Cloud Analytics, Data Platform, and AI Workflow' } = Astro.props;
const locale = getLocale(Astro.url.pathname);
const labels = navLabels[locale];
const navItems = [
  [localizePath('/', locale), labels.notes],
  [localizePath('/profile/', locale), labels.profile],
  [localizePath('/portfolio/', locale), labels.portfolio],
  [localizePath('/tag/ai-workflow/', locale), labels.workflow],
  [localizePath('/tags/', locale), labels.tags],
];
const htmlLang = locale === 'ja' ? 'ja' : locale === 'en' ? 'en' : 'ko';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;700;800;900&family=Noto+Sans+KR:wght@400;700;800;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="site-nav" aria-label="Primary navigation">
          <a class="brand" href={localizePath('/', locale)}>Yongtak Notes</a>
          <div class="nav-links">
            {navItems.map(([href, label]) => (
              <a href={href} aria-current={Astro.url.pathname === href ? 'page' : undefined}>{label}</a>
            ))}
          </div>
          <div class="language-links" aria-label="Language">
            {locales.map((item) => (
              <a href={localizePath(Astro.url.pathname, item)} aria-current={locale === item ? 'page' : undefined}>
                {localeLabels[item]}
              </a>
            ))}
          </div>
        </nav>
      </header>
      <slot />
      <footer class="site-footer">
        Yongtak Kim Engineering Notes
      </footer>
    </div>
  </body>
</html>
